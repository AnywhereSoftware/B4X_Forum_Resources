 void Astring(B4R::Object* o) { 
	  Serial.print("read in inlin C : ") ;Serial.println(b4r_main::_st->get()->data);
	  B4R::B4RString tmp;
	  b4r_main::_st->setStr(tmp.wrap("String changed in inline C"));
	  Serial.print("Read after modification : ") ; Serial.println(b4r_main::_st->get()->data);	  
	  b4r_main::_st->addStr(tmp.wrap(" +more String again"));	  
	  
	  Serial.print("Read after second modification : ") ; Serial.println(b4r_main::_st->get()->data);
 };
  
#End If