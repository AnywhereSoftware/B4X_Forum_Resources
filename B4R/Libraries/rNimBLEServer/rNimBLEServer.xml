    <class>
        <name>B4R::B4RNimBLEServer</name>
        <shortname>NimBLEServer</shortname>
        <comment>@class B4RNimBLEServer
@brief Lightweight BLE server wrapper for B4R.</comment>
        <event>Connected ()</event>
        <event>Disconnected ()</event>
        <event>Write (Buffer() As Byte)</event>
        <method>
            <name DesignerName="Initialize">Initialize</name>
            <comment>@brief Initializes the BLE server.
@param DeviceName - Name of the BLE device (advertised)
@param ServiceUUID - UUID of the BLE service
@param CharUUID - UUID of the characteristic (RX/TX combined)
@param OnConnected - Callback when client connects
@param OnDisconnected - Callback when client disconnects
@param OnWrite - Callback when client writes data
@param Debug - Enable serial debug output</comment>
            <returntype>B4R::void</returntype>
            <parameter>
                <name>DeviceName</name>
                <type>B4R::B4RString*</type>
            </parameter>
            <parameter>
                <name>ServiceUUID</name>
                <type>B4R::B4RString*</type>
            </parameter>
            <parameter>
                <name>CharUUID</name>
                <type>B4R::B4RString*</type>
            </parameter>
            <parameter>
                <name>OnConnected</name>
                <type>SubVoidVoid</type>
            </parameter>
            <parameter>
                <name>OnDisconnected</name>
                <type>SubVoidVoid</type>
            </parameter>
            <parameter>
                <name>OnWrite</name>
                <type>SubVoidArray</type>
            </parameter>
            <parameter>
                <name>Debug</name>
                <type>bool</type>
            </parameter>
        </method>
        <method>
            <name DesignerName="Start">Start</name>
            <comment>@brief Starts the BLE server and begins advertising.</comment>
            <returntype>B4R::void</returntype>
        </method>
        <method>
            <name DesignerName="Stop">Stop</name>
            <comment>@brief Stops the BLE server and advertising.</comment>
            <returntype>B4R::void</returntype>
        </method>
        <method>
            <name DesignerName="Write">Write</name>
            <comment>@brief Sends notification to connected client.
@param data Byte array to send</comment>
            <returntype>B4R::void</returntype>
            <parameter>
                <name>data</name>
                <type>Byte[]</type>
            </parameter>
        </method>
        <method>
            <name DesignerName="SetConnected">SetConnected</name>
            <comment>@brief Set cleitn connection state.
@param state bool true or false</comment>
            <returntype>B4R::void</returntype>
            <parameter>
                <name>state</name>
                <type>bool</type>
            </parameter>
        </method>
        <method>
            <name DesignerName="IsConnected">IsConnected</name>
            <comment>@brief Returns connection status.</comment>
            <returntype>bool</returntype>
        </method>
